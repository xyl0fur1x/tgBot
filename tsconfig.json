{
  "compilerOptions": {
    /* Output */
    "outDir": "./test_dist", /* ./dist   ./test_dist   */ 
    "rootDir": "./src",
    "removeComments": true,
    "sourceMap": false,
    "declaration": false,

    /* Environment */
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "lib": ["ES2022"],
    "types": ["node"],

    /* Interop */
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,

    /* Strictness */
    "strict": true,
    "noImplicitOverride": true,
    "noUncheckedIndexedAccess": true,
    "exactOptionalPropertyTypes": true,

    /* Safety */
    "forceConsistentCasingInFileNames": true,
    "skipLibCheck": true,

    /* Performance */
    "incremental": true,
    "tsBuildInfoFile": ".tsbuildinfo"
  },
  "include": ["src"],
  "exclude": ["node_modules", "dist"]
}
